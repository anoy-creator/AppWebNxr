<section class="page container">
    <div class="page-heading">
        <span>TEAM</span>
        <h1>Nos Joueurs</h1>
    </div>
    <div class="filter-row">
        {% for filter in ['Tous', 'Staff', 'Joueur', 'Streamer', 'Createur'] %}
            <span>{{ filter }}</span>
        {% endfor %}
    </div>
    <div class="card-grid three">
        {% for player in data.players %}
            <article class="player-card">
                <div class="player-photo">
                    <img src="{{ player.avatar }}" alt="">
                    <span>{{ player.role }}</span>
                    <div>
                        <h2>{{ player.pseudo }}</h2>
                        <p>{{ player.grade }}</p>
                    </div>
                </div>
                <div class="player-meta">
                    <span>Jeu principal</span>
                    <strong>{{ player.game }}</strong>
                </div>
                <div class="social-row card-socials">
                    {% for network, handle in player.socials %}
                        <a href="#" aria-label="{{ network }}">{{ network|slice(0, 2)|upper }}</a>
                    {% endfor %}
                </div>
            </article>
        {% endfor %}
    </div>
</section>
