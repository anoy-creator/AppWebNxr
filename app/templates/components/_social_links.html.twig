{% set socials = socials|default({}) %}
{% set class_name = class_name|default('') %}
{% set social_labels = {
    tiktok: 'TikTok',
    youtube: 'YouTube',
    discord: 'Discord',
    insta: 'Instagram',
    twitter: 'Twitter'
} %}

{% set has_links = false %}
{% for network, label in social_labels %}
    {% set raw_url = socials[network]|default('') %}
    {% set url = raw_url is iterable ? '' : raw_url|trim %}
    {% if url matches '~^https?://~i' %}
        {% set has_links = true %}
    {% endif %}
{% endfor %}

{% if has_links %}
    {% if heading|default('') is not empty %}
        <h3>{{ heading }}</h3>
    {% endif %}

    <div class="social-icon-links {{ class_name }}">
        {% for network, label in social_labels %}
            {% set raw_url = socials[network]|default('') %}
            {% set url = raw_url is iterable ? '' : raw_url|trim %}

            {% if url matches '~^https?://~i' %}
                <a
                    class="social-icon-link social-icon-link--{{ network }}"
                    href="{{ url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="{{ label }}"
                    title="{{ label }}"
                >
                    {% if network == 'tiktok' %}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M14.2 3h3.1c.2 1.9 1.4 3.3 3.2 4v3.2c-1.2-.1-2.2-.4-3.1-1v6a5.4 5.4 0 1 1-5.4-5.4c.4 0 .8 0 1.2.1v3.2a2.2 2.2 0 1 0 1 1.9V3z"/>
                        </svg>
                    {% elseif network == 'youtube' %}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M21.3 7.1a3 3 0 0 0-2.1-2.1C17.3 4.5 12 4.5 12 4.5s-5.3 0-7.2.5a3 3 0 0 0-2.1 2.1A31.2 31.2 0 0 0 2.2 12c0 1.7.2 3.3.5 4.9a3 3 0 0 0 2.1 2.1c1.9.5 7.2.5 7.2.5s5.3 0 7.2-.5a3 3 0 0 0 2.1-2.1c.3-1.6.5-3.2.5-4.9s-.2-3.3-.5-4.9z"/>
                            <path d="M10.2 8.7v6.6L15.8 12z" class="social-icon-cutout"/>
                        </svg>
                    {% elseif network == 'discord' %}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M7.3 6.4A13 13 0 0 1 11 5.3l.5 1a12.7 12.7 0 0 1 1.1 0l.5-1a13 13 0 0 1 3.7 1.1c1.7 2.5 2.5 5.2 2.2 8.2A11 11 0 0 1 15 16.7l-.9-1.2c.5-.2 1-.4 1.4-.7a8.8 8.8 0 0 1-7 0c.4.3.9.5 1.4.7L9 16.7a11 11 0 0 1-4-2.1c-.3-3 .5-5.7 2.3-8.2z"/>
                            <circle cx="9.3" cy="11.5" r="1.1" class="social-icon-cutout"/>
                            <circle cx="14.7" cy="11.5" r="1.1" class="social-icon-cutout"/>
                        </svg>
                    {% elseif network == 'insta' %}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <rect x="4" y="4" width="16" height="16" rx="4.5" ry="4.5"/>
                            <circle cx="12" cy="12" r="3.8" class="social-icon-cutout social-icon-stroke"/>
                            <circle cx="16.9" cy="7.1" r="1.1" class="social-icon-cutout"/>
                        </svg>
                    {% else %}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M5 4h3.7l4.1 5.5L17.5 4H20l-6 7 6.6 9h-3.7l-4.4-6-5.1 6H5l6.3-7.3L5 4zm3 2 9.8 12h.8L8.8 6H8z"/>
                        </svg>
                    {% endif %}
                </a>
            {% endif %}
        {% endfor %}
    </div>
{% endif %}
