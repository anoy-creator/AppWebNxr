<section class="page container">
    <div class="page-heading">
        <span>CUP</span>
        <h1>Nos Rosters</h1>
    </div>

    <div class="stack">
        {% for roster in rosters %}
            <article class="roster-card js-roster-card" data-roster-id="{{ roster.id }}">
                {% if is_granted('ROLE_ADMIN') %}
                    <button type="button" class="admin-edit-btn" data-admin-edit="roster" data-admin-edit-id="{{ roster.id }}">Modifier</button>
                {% endif %}

                <div class="roster-hero">
                    <img src="{{ roster.banner ?: '/images/roster-default.jpg' }}" alt="{{ roster.name }}">

                    <div class="roster-title">
                        <img src="{{ asset('build/images/NxrLogo.png') }}" alt="NxR" class="logo-mark big">

                        <div>
                            <h2>{{ roster.name }}</h2>
                            <p>{{ roster.game }}</p>
                        </div>
                    </div>
                </div>

                <div class="roster-content">
                    <div class="mini-stats big-stats">
                        <span><strong>{{ roster.wins }}</strong> Victoires</span>
                        <span><strong>{{ roster.losses }}</strong> Défaites</span>
                        <span><strong>{{ roster.winrate }}</strong> Winrate</span>
                    </div>

                    <h3>Composition</h3>

                    <div class="composition-grid">
                        {% for player in roster.players %}
                            <span>
                                {{ player.pseudo }}
                                <em>{{ player.grade }}</em>
                            </span>
                        {% else %}
                            <span>Aucun joueur</span>
                        {% endfor %}
                    </div>
                </div>
            </article>
        {% else %}
            <p>Aucun roster disponible.</p>
        {% endfor %}
    </div>
</section>

<div class="roster-modal" id="rosterModal" aria-hidden="true">
    <div class="roster-modal-overlay js-close-roster-modal"></div>

    <div class="roster-modal-box">
        <button type="button" class="roster-modal-close js-close-roster-modal">×</button>
        <div id="rosterModalContent"></div>
    </div>
</div>
