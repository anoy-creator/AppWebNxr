<section class="hero">
    <div class="hero-content">
        <img src="{{ asset('build/images/NxrLogo.png') }}" alt="NxR" class="hero-logo">
        <img src="{{ asset('build/images/banNaxeria.png') }}" alt="NxR" class="ban-b-acc">

        <p class='hero-text'>"One Team. One Vision. NxR."</p>
        <div class="hero-actions">
            <a class="button button-primary" href="{{ path('app_players') }}">Rejoindre la team</a>
            <a class="button button-ghost" href="{{ path('app_rosters') }}">Voir nos rosters</a>
        </div>
    </div>
</section>

<section class="section container">
    <div class="stat-grid">
        <article class="stat-card"><span>Team</span><strong>{{ nbMembre }}</strong><p>Membres</p></article>
        <article class="stat-card"><span>Aim</span><strong>{{ matchesPlayed }}</strong><p>Matchs joues</p></article>
        <article class="stat-card"><span>Cup</span><strong>{{ tournamentsWon }}</strong><p>Tournois gagnes</p></article>
        <article class="stat-card"><span>Rate</span><strong>{{ winrate }}</strong><p>Winrate</p></article>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-title">
            <h2>Actualites recentes</h2>
            <a href="{{ path('app_news') }}">Voir tout -></a>
        </div>
        <div class="card-grid three">
            {% for item in news|slice(0, 3) %}
                <article class="image-card">
                    <img src="{{ item.image }}" alt="">
                    <div class="card-body">
                        <h3>{{ item.title }}</h3>
                        <p>{{ item.excerpt }}</p>
                        <small>{{ item.author }} - {{ item.date|date('d/m/Y') }}</small>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section container">
    <div class="section-title">
        <h2>Rosters actifs</h2>
    </div>
    <div class="card-grid two">
        {% for roster in rosters %}
            <article class="roster-card compact">
                <div class="roster-banner">
                    <img src="{{ roster.banner }}" alt="">
                    <div>
                        <h3>{{ roster.name }}</h3>
                        <p>{{ roster.game }}</p>
                    </div>
                </div>
                <div class="mini-stats">
                    <span><strong>{{ roster.wins }}</strong> Victoires</span>
                    <span><strong>{{ roster.losses }}</strong> Defaites</span>
                    <span><strong>{{ roster.winrate }}</strong> Winrate</span>
                </div>
                <div class="player-list">
                    {% for player in roster.players %}
                        <span>{{ player.pseudo }}<em>{{ player.role }}</em></span>
                    {% endfor %}
                </div>
            </article>
        {% endfor %}
    </div>
    <div class="center-action"><a class="button button-ghost" href="{{ path('app_rosters') }}">Voir tous les rosters</a></div>
</section>

<section class="section section-alt partners">
    <div class="container">
        <h2>Nos partenaires</h2>
        <div class="partner-row"><span>HyperX</span><span>DISCORD</span><span>TWITCH</span></div>
    </div>
</section>
