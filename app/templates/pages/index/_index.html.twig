<section class="hero">
    <div class="hero-content">
        <img src="{{ asset('build/images/NxrLogo.png') }}" alt="NxR" class="hero-logo">
        <img src="{{ asset('build/images/banNaxeria.png') }}" alt="NxR" class="ban-b-acc">

        <p class='hero-text'>"One Team. One Vision. NxR."</p>
        <div class="hero-actions">
            <a class="button button-primary" href="{{ path('app_players') }}">Rejoindre la team</a>
            <a class="button button-ghost" href="{{ path('app_matches') }}">Voir les matchs</a>
        </div>
    </div>
</section>

<section class="section container">
    <div class="stat-grid">
        <article class="stat-card"><span>Team</span><strong>{{ nbMembre }}</strong><p>Membres</p></article>
        <article class="stat-card"><span>Aim</span><strong>{{ matchesPlayed }}</strong><p>Matchs joues</p></article>
        <article class="stat-card"><span>Cup</span><strong>{{ tournamentsWon }}</strong><p>Tournois gagnes</p></article>
        <article class="stat-card"><span>Rate</span><strong>{{ winrate }}</strong><p>Winrate</p></article>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-title">
            <h2>Actualites recentes</h2>
            <a href="{{ path('app_news') }}">Voir tout -></a>
        </div>
        <div class="card-grid three">
            {% for item in news|slice(0, 3) %}
                <article class="image-card js-news-card" data-news-id="{{ item.id }}" role="button" tabindex="0">
                    <img src="{{ item.image }}" alt="">
                    <div class="card-body">
                        <h3>{{ item.title }}</h3>
                        <p>{{ item.excerpt }}</p>
                        <small>{{ item.author }} - {{ item.date|date('d/m/Y') }}</small>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section container">
    <div class="section-title">
        <h2>Derniers matchs joues</h2>
        <a href="{{ path('app_matches') }}">Voir tout -></a>
    </div>

    <div class="home-match-list">
        {% for match in recentMatches %}
            <article class="home-match-card js-match-card" data-match-id="{{ match.id }}" role="button" tabindex="0">
                <div class="home-match-meta">
                    <span>{{ match.playedAt ? match.playedAt|date('d/m/Y H:i') : 'TBD' }}</span>
                    <span>{{ match.game }}</span>
                </div>

                <h3>
                    {{ match.teamA ? match.teamA.name : 'TBA' }}
                    vs
                    {{ match.teamB ? match.teamB.name : 'TBA' }}
                </h3>

                <p>{{ match.mapName ? match.mode ~ ' - ' ~ match.mapName : match.mode }}</p>

                {% if match.result == 'Victory' %}
                    <span class="result win">Victoire</span>
                {% elseif match.result == 'Defeat' %}
                    <span class="result loss">Defaite</span>
                {% else %}
                    <span class="result">A venir</span>
                {% endif %}
            </article>
        {% else %}
            <p>Aucun match joue pour le moment.</p>
        {% endfor %}
    </div>
</section>

<section class="section section-alt partners" hidden aria-hidden="true">
    <div class="container">
        <h2>Nos partenaires</h2>
        <div class="partner-row"><span>HyperX</span><span>DISCORD</span><span>TWITCH</span></div>
    </div>
</section>

<div class="news-modal" id="newsModal" aria-hidden="true">
    <div class="news-modal-overlay js-close-news-modal"></div>

    <div class="news-modal-box">
        <button type="button" class="news-modal-close js-close-news-modal">
            x
        </button>

        <div id="newsModalContent"></div>
    </div>
</div>

<div class="match-modal" id="matchModal" aria-hidden="true">
    <div class="match-modal-overlay js-close-match-modal"></div>

    <div class="match-modal-box">
        <button type="button" class="match-modal-close js-close-match-modal">x</button>
        <div id="matchModalContent"></div>
    </div>
</div>
