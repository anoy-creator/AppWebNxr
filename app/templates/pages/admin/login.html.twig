{% extends 'base.html.twig' %}

{% block title %}Connexion Admin - Naxera{% endblock %}

{% block body %}
    <section class="admin-login-page">
        <div class="admin-login-card">
            <img src="{{ asset('build/images/NxrLogo.png') }}" alt="NxR" class="hero-logo small">
            <h1>Connexion Admin</h1>

            {% if error %}
                <div class="alert alert-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">
                <div class="form-group">
                    <label for="username">Nom d'utilisateur</label>
                    <input
                        type="text"
                        id="username"
                        name="_username"
                        value="{{ last_username }}"
                        required
                        autofocus
                    >
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input
                        type="password"
                        id="password"
                        name="_password"
                        required
                    >
                </div>

                <button type="submit" class="admin-login-btn">Se connecter</button>
            </form>

            <p class="back-link">
                <a href="{{ path('app_index') }}">Retour a l'accueil</a>
            </p>
        </div>
    </section>
{% endblock %}
