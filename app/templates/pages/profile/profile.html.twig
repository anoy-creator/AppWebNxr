<div class="profile-container">
    <h1>Mon profil</h1>
    {% set discordRoles = discordRoles|default([]) %}
    {% set socialNetworks = socialNetworks|default(['tiktok', 'youtube', 'discord', 'insta', 'twitter']) %}
    {% set socialLabels = socialLabels|default({
        tiktok: 'TikTok',
        youtube: 'YouTube',
        discord: 'Discord',
        insta: 'Instagram',
        twitter: 'Twitter'
    }) %}
    {% set player = user.player %}

    <div class="profile-card">
        {% if user.avatar %}
            <img src="{{ user.avatar }}" alt="{{ user.username }}" class="profile-avatar-large">
        {% else %}
            <div class="profile-avatar-large no-avatar">{{ user.username|first|upper }}</div>
        {% endif %}

        <div class="profile-info">
            <h2>{{ user.username }}</h2>
            {% if user.email %}
                <p><strong>Email:</strong> {{ user.maskedEmail }}</p>
            {% endif %}
            <p class="profile-roles"><strong>Roles Discord:</strong>
                {% if discordRoles is not empty %}
                    {% for role in discordRoles %}
                        <span class="badge">{{ role }}</span>
                    {% endfor %}
                {% else %}
                    <span class="profile-muted">Aucun role Discord detecte</span>
                {% endif %}
            </p>
            {% if user.lastLoginAt %}
                <p><strong>Derniere connexion:</strong> {{ user.lastLoginAt|date('d/m/Y H:i') }}</p>
            {% endif %}
        </div>
    </div>

    <div class="profile-social-card">
        <div class="profile-social-heading">
            <h2>Liens reseaux</h2>
            {% if player %}
                {% include 'components/_social_links.html.twig' with {
                    socials: player.socials,
                    class_name: 'profile-social-preview'
                } only %}
            {% endif %}
        </div>

        {% if player %}
            <form class="profile-social-form" data-profile-socials-form>
                <div class="profile-social-grid">
                    {% for network in socialNetworks %}
                        {% set rawUrl = player.socials[network]|default('') %}
                        {% set currentUrl = rawUrl is iterable ? '' : rawUrl|trim %}
                        <label>
                            <span>{{ socialLabels[network]|default(network|capitalize) }}</span>
                            <input
                                name="socials[{{ network }}]"
                                type="url"
                                inputmode="url"
                                placeholder="https://..."
                                value="{{ currentUrl matches '~^https?://~i' ? currentUrl : '' }}"
                            >
                        </label>
                    {% endfor %}
                </div>

                <div class="profile-social-actions">
                    <button type="submit">Enregistrer</button>
                    <span class="profile-social-feedback" data-profile-socials-feedback aria-live="polite"></span>
                </div>
            </form>
        {% else %}
            <p class="profile-muted">Aucun joueur n'est lie a ce profil.</p>
        {% endif %}
    </div>

    <div class="profile-danger-card">
        <div>
            <h2>Zone sensible</h2>
            <p>La suppression efface le compte web et anonymise les donnees personnelles liees au joueur.</p>
        </div>

        <form class="profile-delete-form" data-profile-delete-form data-token="{{ csrf_token('delete_profile') }}">
            <button type="submit">Supprimer mon profil</button>
            <span class="profile-social-feedback" data-profile-delete-feedback aria-live="polite"></span>
        </form>
    </div>
</div>
