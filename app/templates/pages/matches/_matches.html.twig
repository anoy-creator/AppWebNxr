{% set total = games|length %}
{% set victories = games|filter(g => g.result == 'Victory')|length %}
{% set defeats = games|filter(g => g.result == 'Defeat')|length %}
{% set winrate = total > 0 ? ((victories / total) * 100)|number_format(1) : '0.0' %}

<section class="page container">
    <div class="page-heading">
        <span>CUP</span>
        <h1>Historique des Matchs</h1>
    </div>

    <div class="stat-grid match-stats">
        <article class="stat-card">
            <strong>{{ total }}</strong>
            <p>Total matchs</p>
        </article>

        <article class="stat-card">
            <strong class="text-green">{{ victories }}</strong>
            <p>Victoires</p>
        </article>

        <article class="stat-card">
            <strong class="text-red">{{ defeats }}</strong>
            <p>Defaites</p>
        </article>

        <article class="stat-card">
            <strong class="text-purple">{{ winrate }}%</strong>
            <p>Winrate</p>
        </article>
    </div>

    <div class="filter-row match-filter-row">
        {% for filter in matchFilters|default(['Tous', 'CDL', 'Warzone', 'Tournament', 'Hardcore']) %}
            <span
                role="button"
                tabindex="0"
                class="match-filter {{ activeFilter is defined and activeFilter == filter ? 'is-active' : '' }}"
                data-game="{{ filter }}"
            >
                {{ filter }}
            </span>
        {% endfor %}
    </div>

    <div id="matches-content">
        {% if isTournamentView|default(false) %}
            <div class="tournament-group-list">
                {% for group in tournamentGroups|default([]) %}
                    {% set tournament = group.tournament %}
                    <article
                        class="tournament-card js-tournament-card"
                        data-tournament-id="{{ tournament.id }}"
                        role="button"
                        tabindex="0"
                    >
                        <div>
                            <span>{{ tournament.date ? tournament.date|date('d/m/Y') : 'TBD' }}</span>
                            <h2>{{ tournament.title }}</h2>
                            <p>{{ group.matches|length }} match{{ group.matches|length > 1 ? 's' : '' }} lie{{ group.matches|length > 1 ? 's' : '' }} au tournoi</p>
                        </div>

                        <strong>{{ tournament.tournamentFormat ?: 'Format libre' }}</strong>
                    </article>

                    <div class="tournament-match-panel" id="tournament-matches-{{ tournament.id }}">
                        <div class="table-card">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Match</th>
                                        <th>Jeu</th>
                                        <th>Mode</th>
                                        <th>Score</th>
                                        <th>Resultat</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    {% for match in group.matches %}
                                        <tr class="js-match-row" data-match-id="{{ match.id }}">
                                            <td>{{ match.playedAt ? match.playedAt|date('d/m/Y H:i') : '-' }}</td>
                                            <td>
                                                {{ match.teamA ? match.teamA.name : 'TBA' }}
                                                vs
                                                {{ match.teamB ? match.teamB.name : 'TBA' }}
                                            </td>
                                            <td><span class="pill">{{ match.game }}</span></td>
                                            <td>{{ match.mapName ? match.mode ~ ' - ' ~ match.mapName : match.mode }}</td>
                                            <td>{{ match.score ?: '-' }}</td>
                                            <td class="match-result-cell">
                                                {% if match.result == 'Victory' %}
                                                    <span class="result win">Victoire</span>
                                                {% elseif match.result == 'Defeat' %}
                                                    <span class="result loss">Defaite</span>
                                                {% elseif match.result is empty %}
                                                    <span class="result">A venir</span>
                                                {% else %}
                                                    <span class="result">{{ match.result }}</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% else %}
                    <p>Aucun tournoi avec match lie.</p>
                {% endfor %}
            </div>
        {% else %}
            <div id="matches-table-wrapper" class="table-card">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Match</th>
                            <th>Roster</th>
                            <th>Jeu</th>
                            <th>Mode</th>
                            <th>Score</th>
                            <th>Resultat</th>
                            {% if is_granted('ROLE_ADMIN') %}
                                <th>Action</th>
                            {% endif %}
                        </tr>
                    </thead>

                    <tbody id="matches-table-body">
                        {% for match in games %}
                            <tr class="js-match-row" data-match-id="{{ match.id }}">
                                <td>{{ match.playedAt ? match.playedAt|date('d/m/Y H:i') : '-' }}</td>
                                <td>
                                    {{ match.teamA ? match.teamA.name : 'TBA' }}
                                    vs
                                    {{ match.teamB ? match.teamB.name : 'TBA' }}
                                </td>
                                <td>{{ match.roster ? match.roster.name : '-' }}</td>
                                <td>
                                    <span class="pill">{{ match.game }}</span>
                                </td>
                                <td>{{ match.mapName ? match.mode ~ ' - ' ~ match.mapName : match.mode }}</td>
                                <td>{{ match.score ?: '-' }}</td>
                                <td class="match-result-cell">
                                    {% if match.result == 'Victory' %}
                                        <span class="result win">Victoire</span>
                                    {% elseif match.result == 'Defeat' %}
                                        <span class="result loss">Defaite</span>
                                    {% elseif match.result is empty %}
                                        <span class="result">A venir</span>
                                    {% else %}
                                        <span class="result">{{ match.result }}</span>
                                    {% endif %}
                                </td>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <td>
                                        <button type="button" class="admin-edit-inline-btn" data-admin-edit="match" data-admin-edit-id="{{ match.id }}">Modifier</button>
                                    </td>
                                {% endif %}
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="{{ is_granted('ROLE_ADMIN') ? 8 : 7 }}">Aucun match disponible.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</section>

<div class="match-modal" id="matchModal" aria-hidden="true">
    <div class="match-modal-overlay js-close-match-modal"></div>

    <div class="match-modal-box">
        <button type="button" class="match-modal-close js-close-match-modal">x</button>
        <div id="matchModalContent"></div>
    </div>
</div>
