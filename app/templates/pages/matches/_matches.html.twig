{% set total = games|length %}
{% set victories = games|filter(g => g.result == 'Victory')|length %}
{% set defeats = games|filter(g => g.result == 'Defeat')|length %}
{% set winrate = total > 0 ? ((victories / total) * 100)|number_format(1) : '0' %}

<section class="page container">
    <div class="page-heading">
        <span>CUP</span>
        <h1>Historique des Matchs</h1>
    </div>

    <div class="stat-grid match-stats">
        <article class="stat-card"><strong>{{ total }}</strong><p>Total matchs</p></article>
        <article class="stat-card green"><strong>{{ victories }}</strong><p>Victoires</p></article>
        <article class="stat-card red"><strong>{{ defeats }}</strong><p>Defaites</p></article>
        <article class="stat-card purple"><strong>{{ winrate }}%</strong><p>Winrate</p></article>
    </div>

    <div class="filter-row">
        {% for filter in ['Tous', 'CDL', 'Warzone', 'Tournament'] %}
            <span>{{ filter }}</span>
        {% endfor %}
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Match</th>
                    <th>Jeu</th>
                    <th>Mode</th>
                    <th>Score</th>
                    <th>Résultat</th>
                </tr>
            </thead>

            <tbody>
                {% for match in games %}
                    <tr>
                        <td>{{ match.playedAt ? match.playedAt|date('d/m/Y') : '-' }}</td>

                        <td>
                            {{ match.teamA ? match.teamA.name : 'TBA' }}
                            vs
                            {{ match.teamB ? match.teamB.name : 'TBA' }}
                        </td>

                        <td>
                            <span class="pill">{{ match.game }}</span>
                        </td>

                        <td>{{ match.mode }}</td>

                        <td>{{ match.score }}</td>

                        <td>
                            {% if match.result == 'Victory' %}
                                <span class="result win">Victoire</span>
                            {% elseif match.result == 'Defeat' %}
                                <span class="result loss">Défaite</span>
                            {% else %}
                                <span class="result">{{ match.result }}</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">Aucun match disponible.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
