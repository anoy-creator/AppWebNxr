<section class="page container">
    <div class="page-heading">
        <span>TEAM</span>
        <h1>Nos Joueurs</h1>
    </div>

    <div class="filter-row">
        <span role="button" tabindex="0" class="player-filter is-active" data-role="all">Tous</span>
        <span role="button" tabindex="0" class="player-filter" data-role="Staff">Staff</span>
        <span role="button" tabindex="0" class="player-filter" data-role="Joueur">Joueur</span>
        <span role="button" tabindex="0" class="player-filter" data-role="Streamer">Streamer</span>
        <span role="button" tabindex="0" class="player-filter" data-role="Createur">Créateur</span>
    </div>

    <div id="players-grid" class="card-grid three">
        {% for player in players %}
            <article class="player-card js-player-card" data-player-id="{{ player.id }}">
                <div class="player-photo">
                    <img
                        src="{{ player.avatar ?: '/images/default-avatar.png' }}"
                        alt="{{ player.pseudo }}"
                    >

                    <span>
                        {{ player.roster ? player.roster.name : 'Sans roster' }}
                    </span>

                    <div>
                        <h2>{{ player.pseudo }}</h2>
                        <p>{{ player.grade }}</p>
                    </div>
                </div>

                <div class="player-meta">
                    <span>Rôle</span>
                    <strong>{{ player.role }}</strong>
                </div>

                <div class="player-meta">
                    <span>Jeu principal</span>
                    <strong>{{ player.game }}</strong>
                </div>

                {% if player.socials is not empty %}
                    <div class="social-links">
                        {% for network, account in player.socials %}
                            <span>{{ network }} : {{ account }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>
        {% else %}
            <p>Aucun joueur trouvé.</p>
        {% endfor %}
    </div>
</section>

<div class="player-modal" id="playerModal" aria-hidden="true">
    <div class="player-modal-overlay js-close-player-modal"></div>

    <div class="player-modal-box">
        <button type="button" class="player-modal-close js-close-player-modal">
            ×
        </button>

        <div id="playerModalContent"></div>
    </div>
</div>

{{ encore_entry_script_tags('joueur') }}
