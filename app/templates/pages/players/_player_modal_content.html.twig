<div class="player-modal-header">
    <img src="{{ player.avatar ?: '/images/default-avatar.png' }}" alt="{{ player.pseudo }}">

    <div>
        <span class="player-modal-roster">
            {{ player.roster ? player.roster.name : 'Sans roster' }}
        </span>

        <h2>{{ player.pseudo }}</h2>
        <p>{{ player.grade }}</p>
    </div>
</div>

<div class="player-modal-body">
    <div class="player-modal-info">
        <span>Rôle</span>
        <strong>{{ player.role }}</strong>
    </div>

    <div class="player-modal-info">
        <span>Jeu principal</span>
        <strong>{{ player.game }}</strong>
    </div>

    {% if player.roster %}
        <div class="player-modal-info">
            <span>Roster</span>
            <strong>{{ player.roster.name }}</strong>
        </div>
    {% endif %}

    {% if player.socials is not empty %}
        <div class="player-modal-socials">
            <h3>Réseaux</h3>

            {% for network, account in player.socials %}
                <p>
                    <strong>{{ network|capitalize }}</strong>
                    <span>{{ account }}</span>
                </p>
            {% endfor %}
        </div>
    {% endif %}
</div>
