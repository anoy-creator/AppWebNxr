<div class="player-modal-header">
    <img src="{{ player.avatar ?: '/images/default-avatar.png' }}" alt="{{ player.pseudo }}">

    <div>
        <h2>{{ player.pseudo }}</h2>
        <p>{{ player.grade }}</p>
    </div>
</div>

<div class="player-modal-body">
    <div class="player-modal-info">
        <span>Role</span>
        <strong>{{ player.role }}</strong>
    </div>

    <div class="player-modal-info">
        <span>Jeu principal</span>
        <strong>{{ player.game }}</strong>
    </div>

    <div class="player-modal-socials">
        {% include 'components/_social_links.html.twig' with {
            socials: player.socials,
            heading: 'Reseaux',
            class_name: 'player-modal-social-links'
        } only %}
    </div>
</div>
